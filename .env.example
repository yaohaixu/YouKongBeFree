# Server
PORT=8080

# Initial admin account. The real values should live in `.env` or the CloudBase console, not in Git.
YKADMIN_NICKNAME=有空管理员
YKADMIN_PHONE=请替换为管理员手机号

# Storage driver: json for local development, cloudbase for Tencent CloudBase.
STORE_DRIVER=json
CLOUDBASE_ENV_ID=youkong-d5gh4x0ayc29a2187

# Security controls.
# Comma-separated origins that may call the API with credentials.
CORS_ORIGINS=https://youkong-d5gh4x0ayc29a2187-1441855189.tcloudbaseapp.com

# Anonymous identity / Community OS.
# Use a long random value in production; changing it will create new anonymous identities.
IDENTITY_HASH_SALT=请替换为长随机字符串

# Cloudflare Turnstile. Disabled by default; local development can bypass it.
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_BYPASS_LOCAL=true

# AI Analysis Engine config encryption. Use a stable long random value in production.
AI_CONFIG_ENCRYPTION_KEY=请替换为长随机字符串

# Session lifetime in days. The server clamps this value to 1-30 days.
SESSION_MAX_AGE_DAYS=14

# Activity auto-ending.
# Activities are marked ended after their activity date passes in Asia/Shanghai.
ACTIVITY_AUTO_END_INTERVAL_MS=900000
ACTIVITY_AUTO_END_MIN_SWEEP_MS=60000
DISABLE_ACTIVITY_AUTO_END=false

# API timing diagnostics.
# Slow API requests and 5xx responses are logged to server / CloudBase function logs.
API_TIMING_LOGS=true
API_SLOW_LOG_MS=1200

# Optional local JSON database path for smoke tests.
YK_DB_FILE=
